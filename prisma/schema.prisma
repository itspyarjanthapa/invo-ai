generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model user {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  name      String?
  clerkId   String   @unique
  clients   client[]
}

model client {
  id        String   @id @default(cuid())
  userId    String
  name      String
  email     String
  company   String?
  address   String?
  phone     String?
  createdAt DateTime @default(now())
  user      user     @relation(fields: [userId], references: [id])
}
